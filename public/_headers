# Cloudflare Pages _headers
# Adds long-term cache for static assets (images, fonts, etc.)
# https://developers.cloudflare.com/pages/platform/headers/

# Lenormand card images — cache for 1 year (immutable, never changes)
/lenormand/*
  Cache-Control: public, max-age=31536000, immutable

# Other static images
/*.jpg
  Cache-Control: public, max-age=31536000, immutable

/*.png
  Cache-Control: public, max-age=31536000, immutable

/*.webp
  Cache-Control: public, max-age=31536000, immutable

# Fonts
/*.woff2
  Cache-Control: public, max-age=31536000, immutable

/*.woff
  Cache-Control: public, max-age=31536000, immutable

# JS/CSS bundles — cache with revalidation
/_next/static/*
  Cache-Control: public, max-age=31536000, immutable
